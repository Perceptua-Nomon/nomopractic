i2c_bus = 1
hat_address = 0x14
socket_path = "/run/nomopractic/nomopractic.sock"
socket_mode = 432  # 0o660
log_level = "info"
servo_default_ttl_ms = 500
motor_default_ttl_ms = 500
watchdog_poll_ms = 100

# Motor channel configuration — Robot HAT V4 TC1508S H-bridge driver.
# Each [[motors]] entry maps an IPC motor index (0-based) to a hardware PWM
# channel (12–15) and a BCM GPIO direction pin.  The entries below match the
# SunFounder PicarX wiring; adjust pwm_channel, dir_pin_bcm, and reversed for
# other robot configurations.

[[motors]]
pwm_channel = 12   # P12
dir_pin_bcm = 24   # D5 (BCM 24)
reversed    = false

[[motors]]
pwm_channel = 13   # P13
dir_pin_bcm = 23   # D4 (BCM 23)
reversed    = true  # right motor is wired with reversed polarity on PicarX
