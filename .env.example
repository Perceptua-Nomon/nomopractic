# nomopractic Environment Variables
# Copy this file to .env and fill in values.
# .env is gitignored — never commit secrets or credentials here.
#
# IMPORTANT: This file is for deployment-specific and sensitive values ONLY.
# All non-sensitive configuration (I2C bus, socket path, TTL defaults, log levels, etc.)
# is in config.toml and ready to use when you clone the repo.
#
# You likely only need to set NOMON_PI_HOST and NOMON_SSH_KEY for deployment.

# =============================================================================
# Deployment (scripts/deploy.sh)
# =============================================================================

# SSH target for the Raspberry Pi — "user@hostname" or plain IP.
# Required by scripts/deploy.sh for remote deployment.
# Example: NOMON_PI_HOST=pi@raspberrypi.local
NOMON_PI_HOST=

# Optional path to an SSH private key.  Omit to use ssh-agent or the default
# ~/.ssh/id_* identity.
# Example: NOMON_SSH_KEY=~/.ssh/id_ed25519
NOMON_SSH_KEY=

# Optional GitHub repository slug for release downloads from GitHub Actions/Releases.
# Default: Perceptua-Nomon/nomopractic
# Only needed if deploying from a fork or custom repository.
# NOMON_GITHUB_REPO=Perceptua-Nomon/nomopractic
